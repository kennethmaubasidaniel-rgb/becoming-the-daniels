    <!-- Firebase SDKs -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-app.js";
        import { getFirestore, collection, addDoc, serverTimestamp } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-firestore.js";
        import { getAuth, signInAnonymously } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-auth.js";

        const firebaseConfig = JSON.parse(__firebase_config);
        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const auth = getAuth(app);
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'wedding-daniels';

        const rsvpForm = document.getElementById('rsvp-form');
        const successDiv = document.getElementById('rsvp-success');
        const submitBtn = document.getElementById('submit-btn');

        const checkExistingRSVP = () => {
            const savedData = localStorage.getItem('daniels_rsvp_final');
            if (savedData) {
                const data = JSON.parse(savedData);
                showSuccess(data.name, data.attendance);
            }
        };

        const showSuccess = (name, attendance) => {
            rsvpForm.classList.add('hidden');
            successDiv.classList.remove('hidden');
            document.getElementById('saved-name').textContent = name;
            if (attendance === 'Declines') {
                document.getElementById('success-status').textContent = "We have received your response. You will be greatly missed!";
            }
        };

        signInAnonymously(auth).catch(err => console.error("Auth init failed"));

        rsvpForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const name = document.getElementById('guest-name').value.trim();
            const phone = document.getElementById('guest-phone').value.trim();
            const attendance = document.querySelector('input[name="attendance"]:checked').value;

            if (!name || !phone) return;

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="loading-spinner"></span> Processing';

            try {
                const firestorePromise = addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'responses'), {
                    name, phone, attendance, timestamp: serverTimestamp()
                });

                const formData = new FormData(rsvpForm);
                const formspreePromise = fetch(rsvpForm.action, {
                    method: rsvpForm.method,
                    body: formData,
                    headers: { 'Accept': 'application/json' }
                });

                await Promise.all([firestorePromise, formspreePromise]);

                localStorage.setItem('daniels_rsvp_final', JSON.stringify({ name, attendance }));
                showSuccess(name, attendance);
            } catch (error) {
                console.error("Submission error:", error);
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Error - Try Again';
            }
        });

        checkExistingRSVP();
    </script>

    <script>
        const reveal = () => {
            const reveals = document.querySelectorAll('.reveal');
            reveals.forEach(el => {
                const windowHeight = window.innerHeight;
                const revealTop = el.getBoundingClientRect().top;
                if (revealTop < windowHeight - 100) {
                    el.classList.add('active');
                }
            });
        };
        window.addEventListener('scroll', reveal);
        window.onload = reveal;

        const menuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        
        const toggleMenu = () => {
            mobileMenu.classList.toggle('hidden');
            document.body.classList.toggle('overflow-hidden');
        };

        menuBtn.addEventListener('click', toggleMenu);
        
        mobileMenu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.add('hidden');
                document.body.classList.remove('overflow-hidden');
            });
        });

        async function copyAccount() {
            const accNum = document.getElementById('account-num').textContent;
            const textToCopy = `Ecobank | Kenneth Daniel | ${accNum}`;
            
            try {
                const textArea = document.createElement("textarea");
                textArea.value = textToCopy;
                document.body.appendChild(textArea);
                textArea.select();
                document.execCommand('copy');
                document.body.removeChild(textArea);
                
                const msg = document.getElementById('copy-msg');
                msg.style.opacity = '1';
                setTimeout(() => msg.style.opacity = '0', 2500);
            } catch (err) {
                console.error('Copy failed');
            }
        }
    </script>
</body>
