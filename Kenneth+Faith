    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Montserrat:wght@200;300;400;600&family=Great+Vibes&display=swap" rel="stylesheet">
    <style>
        :root {
            --accent: #722F37;
            --secondary: #2D5A27;
            --bg-light: #F9F7F2;
            --text-main: #2D2D2D;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-main);
            scroll-behavior: smooth;
        }

        h1, h2, h3, .serif {
            font-family: 'Cormorant Garamond', serif;
        }

        .cursive {
            font-family: 'Great Vibes', cursive;
        }

        .glass-nav {
            background: rgba(249, 247, 242, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(114, 47, 55, 0.05);
        }

        .reveal {
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        .input-minimal {
            background: transparent;
            border: none;
            border-bottom: 1px solid #D1D1D1;
            border-radius: 0;
            padding: 0.75rem 0;
            transition: all 0.3s;
        }

        .input-minimal:focus {
            outline: none;
            border-bottom-color: var(--accent);
            padding-left: 4px;
        }

        .btn-primary {
            background-color: var(--accent);
            color: white;
            padding: 1rem 2rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            font-size: 0.75rem;
            font-weight: 600;
            transition: all 0.4s;
            position: relative;
            overflow: hidden;
            display: inline-block;
        }

        .btn-primary:disabled {
            background-color: #a3a3a3;
            cursor: not-allowed;
        }

        .loading-spinner {
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top: 2px solid #fff;
            width: 14px;
            height: 14px;
            animation: spin 0.8s linear infinite;
            display: inline-block;
        }

        @keyframes spin { 100% { transform: rotate(360deg); } }

        .img-float {
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            border-radius: 2px;
        }
        
        .hidden-field { display: none !important; visibility: hidden !important; }

        .hero-zoom {
            animation: slowZoom 20s infinite alternate linear;
        }

        @keyframes slowZoom {
            from { transform: scale(1); }
            to { transform: scale(1.15); }
        }
    </style>
</head>
